# Variables para docker-compose (cópialo a .env y rellena los valores).
# docker compose lee automáticamente el archivo .env.

# Secreto para firmar los JWT internos (mínimo 32 caracteres).
JWT_SECRET=relatos-de-papel-super-secret-key-change-in-prod-please-256

# Usuario no predeterminado: RabbitMQ bloquea guest desde otros contenedores.
RABBITMQ_USERNAME=relatos
RABBITMQ_PASSWORD=relatos_password

# Credenciales SMTP de Gmail (usar una "App Password", no la del correo).
GMAIL_USERNAME=tu-correo@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Clave de la API de Gemini (versión gratuita) para el chat de soporte.
GEMINI_API_KEY=tu-api-key-de-gemini
GEMINI_MODEL=gemini-2.5-flash

# Orígenes permitidos por Gateway y WebSocket (separados por comas).
CORS_ALLOWED_ORIGINS=http://localhost:5173
